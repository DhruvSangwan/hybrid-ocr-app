{
  "name": "hybrid-ocr-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^3.4.17",
    "tesseract.js": "^6.0.1",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.dhruv.hybridocrdesktop",
    "productName": "Hybrid OCR Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "C:/Python313",
        "to": "runtime/python"
      },
      {
        "from": "C:/Program Files/Tesseract-OCR",
        "to": "runtime/Tesseract-OCR"
      },
      {
        "from": "C:/Program Files/gs",
        "to": "runtime/gs"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Hybrid-OCR-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
